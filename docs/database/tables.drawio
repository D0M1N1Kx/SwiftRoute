        <mxCell id="4jRvdRW5p3dqNuqbQAD4-424" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontStyle=1;fontSize=24;" value="ORDERS" vertex="1">
          <mxGeometry height="30" width="60" x="680" y="630" as="geometry" />
        </mxCell>
        <mxCell id="4jRvdRW5p3dqNuqbQAD4-426" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=24;fontStyle=1" value="AUTH" vertex="1">
